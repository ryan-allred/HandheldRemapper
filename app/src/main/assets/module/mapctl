#!/system/bin/sh
MODDIR=${0%/*}
CONFIG="$MODDIR/config"
LOG=/data/local/tmp/handheld_remapperd.log
PIDFILE=/data/local/tmp/handheld_remapperd.pid
STOPFILE=/data/local/tmp/handheld_remapperd.disabled
LISTEN_REQUEST=/data/local/tmp/handheld_remapperd.listen
LISTEN_RESULT=/data/local/tmp/handheld_remapperd.listen.result

usage() { cat <<'USAGE'
Handheld Remapper native CLI
Commands: status, logs [n], restart, stop, start, listen [seconds], preset starbound, set-input <input> <target>, set-mouse-axes <x> <y>, mouse-config <cx> <cy> <deadzone> <speed> [intervalMs], show-config, test-wheel [up|down], debug-report
USAGE
}

load_cfg() { EVENT_NAME="Xbox Wireless Controller"; OUTPUT_NAME="Handheld Remapper Keyboard"; OUTPUT_MOUSE_NAME="Handheld Remapper Mouse"; DEBUG=0; BLOCK_ORIGINAL_INPUT=1; MOUSE_AXIS_X="ABS_Z"; MOUSE_AXIS_Y="ABS_RZ"; MOUSE_CENTER_X=0; MOUSE_CENTER_Y=0; MOUSE_MIN_X=-32768; MOUSE_MAX_X=32767; MOUSE_MIN_Y=-32768; MOUSE_MAX_Y=32767; MOUSE_DEADZONE=50; MOUSE_SPEED=8; MOUSE_INTERVAL_MS=1; [ -f "$CONFIG" ] && . "$CONFIG"; }
write_maps() { tmp="$1"; { echo "EVENT_NAME=\"$EVENT_NAME\""; echo "OUTPUT_NAME=\"$OUTPUT_NAME\""; echo "OUTPUT_MOUSE_NAME=\"$OUTPUT_MOUSE_NAME\""; echo "DEBUG=$DEBUG"; echo "BLOCK_ORIGINAL_INPUT=$BLOCK_ORIGINAL_INPUT"; echo "MOUSE_AXIS_X=\"$MOUSE_AXIS_X\""; echo "MOUSE_AXIS_Y=\"$MOUSE_AXIS_Y\""; echo "MOUSE_CENTER_X=$MOUSE_CENTER_X"; echo "MOUSE_CENTER_Y=$MOUSE_CENTER_Y"; echo "MOUSE_MIN_X=$MOUSE_MIN_X"; echo "MOUSE_MAX_X=$MOUSE_MAX_X"; echo "MOUSE_MIN_Y=$MOUSE_MIN_Y"; echo "MOUSE_MAX_Y=$MOUSE_MAX_Y"; echo "MOUSE_DEADZONE=$MOUSE_DEADZONE"; echo "MOUSE_SPEED=$MOUSE_SPEED"; echo "MOUSE_INTERVAL_MS=$MOUSE_INTERVAL_MS"; i=1; while IFS= read -r m; do [ -n "$m" ] && echo "MAP_$i=\"$m\"" && i=$((i+1)); done < "$tmp"; } > "$CONFIG"; }
current_maps() { tmp="$1"; : > "$tmp"; i=1; while :; do eval m=\${MAP_$i:-}; [ -z "$m" ] && break; echo "$m" >> "$tmp"; i=$((i+1)); done; }
input_key() { IFS=:; set -- $1; IFS=' '; [ "$1" = axis ] && echo "axis:$2:$3" || { [ "$1" = button ] && echo "button:$2"; }; }
set_input() { load_cfg; in="$1"; target="$2"; new="$in:$target"; tmp=/data/local/tmp/handheld_mapctl.$$; : > "$tmp"; i=1; while :; do eval m=\${MAP_$i:-}; [ -z "$m" ] && break; [ "$(input_key "$m")" != "$in" ] && echo "$m" >> "$tmp"; i=$((i+1)); done; echo "$new" >> "$tmp"; write_maps "$tmp"; rm -f "$tmp"; echo "mapped $in -> $target"; }
restart() { stop >/dev/null 2>&1; start; }
stop() { touch "$STOPFILE"; rm -f "$LISTEN_REQUEST" "$LISTEN_RESULT"; p=$(cat "$PIDFILE" 2>/dev/null); [ -n "$p" ] && kill "$p" 2>/dev/null; sleep 1; echo stopped; }
start() { rm -f "$STOPFILE" "$LISTEN_REQUEST" "$LISTEN_RESULT"; : > "$LOG"; "$MODDIR/handheld_remapperd" "$CONFIG" >> "$LOG" 2>&1 & sleep 1; tail -n 80 "$LOG"; }
status() { echo "module=$MODDIR"; cat "$MODDIR/module.prop"; echo "pid=$(cat "$PIDFILE" 2>/dev/null)"; echo "disabled=$([ -f "$STOPFILE" ] && echo yes || echo no)"; echo "--- config ---"; cat "$CONFIG"; }
listen_input() {
  timeout="${1:-12}"
  case "$timeout" in ''|*[!0-9]*) timeout=12 ;; esac
  [ "$timeout" -lt 1 ] && timeout=1
  p=$(cat "$PIDFILE" 2>/dev/null)
  if [ -z "$p" ] || ! kill -0 "$p" 2>/dev/null; then
    echo not-running
    exit 2
  fi
  rm -f "$LISTEN_RESULT"
  echo "$$" > "$LISTEN_REQUEST"
  i=0
  limit=$((timeout * 20))
  while [ "$i" -lt "$limit" ]; do
    if [ -s "$LISTEN_RESULT" ]; then
      cat "$LISTEN_RESULT"
      rm -f "$LISTEN_REQUEST" "$LISTEN_RESULT"
      exit 0
    fi
    sleep 0.05
    i=$((i+1))
  done
  rm -f "$LISTEN_REQUEST"
  echo timeout
  exit 1
}
test_wheel() { dir="${1:-up}"; val=0x78; [ "$dir" = down ] && val=0x88; /system/bin/hid - <<EOF
{"id":9,"command":"register","name":"Handheld Remapper Wheel Test","vid":0x5247,"pid":0x0510,"bus":"usb","descriptor":[0x05,0x01,0x09,0x02,0xa1,0x01,0x09,0x01,0xa1,0x00,0x05,0x09,0x19,0x01,0x29,0x08,0x15,0x00,0x25,0x01,0x95,0x08,0x75,0x01,0x81,0x02,0x05,0x01,0x09,0x30,0x09,0x31,0x09,0x38,0x15,0x81,0x25,0x7f,0x75,0x08,0x95,0x03,0x81,0x06,0xc0,0xc0]}
{"id":9,"command":"delay","duration":500}
{"id":9,"command":"report","report":[0x00,0x00,0x00,$val]}
{"id":9,"command":"delay","duration":25}
{"id":9,"command":"report","report":[0x00,0x00,0x00,0x00]}
EOF
 echo "sent wheel $dir test report"; }
debug_report() { echo "--- status ---"; status; echo "--- listen state ---"; ls -l "$LISTEN_REQUEST" "$LISTEN_RESULT" 2>/dev/null || true; cat "$LISTEN_RESULT" 2>/dev/null || true; echo "--- daemon log ---"; logs 240; echo "--- input devices ---"; getevent -lp; echo "--- processes ---"; ps -A 2>/dev/null | grep -E 'handheld_remapperd|hid' || true; }
preset_starbound() { cat > "$CONFIG" <<'CFG'
EVENT_NAME="Xbox Wireless Controller"
OUTPUT_NAME="Handheld Remapper Keyboard"
OUTPUT_MOUSE_NAME="Handheld Remapper Mouse"
DEBUG=0
BLOCK_ORIGINAL_INPUT=1
MOUSE_AXIS_X="ABS_Z"
MOUSE_AXIS_Y="ABS_RZ"
MOUSE_CENTER_X=0
MOUSE_CENTER_Y=0
MOUSE_MIN_X=-32768
MOUSE_MAX_X=32767
MOUSE_MIN_Y=-32768
MOUSE_MAX_Y=32767
MOUSE_DEADZONE=50
MOUSE_SPEED=8
MOUSE_INTERVAL_MS=1
MAP_1="axis:ABS_HAT0X:-:KEY_A"
MAP_2="axis:ABS_HAT0X:+:KEY_D"
MAP_3="axis:ABS_HAT0Y:-:KEY_W"
MAP_4="axis:ABS_HAT0Y:+:KEY_S"
CFG
 echo preset written; }
cmd="$1"; shift 2>/dev/null || true
case "$cmd" in status) status ;; logs) tail -n "${1:-100}" "$LOG" ;; restart) restart ;; stop) stop ;; start) start ;; listen) listen_input "$1" ;; preset) [ "$1" = starbound ] && preset_starbound || usage ;; set-input) set_input "$1" "$2" ;; set-mouse-axes) load_cfg; MOUSE_AXIS_X="$1"; MOUSE_AXIS_Y="$2"; tmp=/data/local/tmp/handheld_mapctl.$$; current_maps "$tmp"; write_maps "$tmp"; rm -f "$tmp" ;; mouse-config) load_cfg; MOUSE_CENTER_X="$1"; MOUSE_CENTER_Y="$2"; MOUSE_DEADZONE="$3"; MOUSE_SPEED="$4"; [ -n "$5" ] && MOUSE_INTERVAL_MS="$5"; tmp=/data/local/tmp/handheld_mapctl.$$; current_maps "$tmp"; write_maps "$tmp"; rm -f "$tmp" ;; show-config) cat "$CONFIG" ;; test-wheel) test_wheel "$1" ;; debug-report) debug_report ;; *) usage ;; esac
